{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonchanggi.github.io/kelly/schemas/kelly-price-series.schema.json",
  "title": "Kelly live normalized price series",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contract",
    "state",
    "generatedAt",
    "dataAsOf",
    "symbols",
    "metadata",
    "dates",
    "prices",
    "returns",
    "fx",
    "source",
    "limitations"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "contract": { "const": "kelly-price-series" },
    "state": { "$ref": "#/$defs/state" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "dataAsOf": {
      "oneOf": [
        { "type": "string", "format": "date" },
        { "type": "null" }
      ]
    },
    "symbols": {
      "type": "array",
      "maxItems": 5,
      "items": { "type": "string", "minLength": 1, "maxLength": 24 }
    },
    "metadata": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "symbol", "name", "assetType", "exchange", "currency", "timezone", "returnBasis"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "symbol": { "type": "string", "minLength": 1, "maxLength": 24 },
          "name": { "type": "string", "minLength": 1 },
          "assetType": { "type": "string", "enum": ["equity", "etf", "index", "fx"] },
          "exchange": { "type": "string", "minLength": 1 },
          "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
          "timezone": { "type": "string", "minLength": 1 },
          "returnBasis": {
            "type": "string",
            "enum": ["price_return", "total_return_approximation", "fx_rate"]
          },
          "priceField": {
            "type": "string",
            "enum": ["close", "adjusted_close"]
          }
        }
      }
    },
    "dates": {
      "type": "array",
      "maxItems": 5000,
      "items": { "type": "string", "format": "date" }
    },
    "prices": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "array",
        "maxItems": 5000,
        "items": { "type": ["number", "null"], "exclusiveMinimum": 0 }
      }
    },
    "returns": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "array",
        "maxItems": 5000,
        "items": { "type": ["number", "null"] }
      }
    },
    "fx": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["base", "quote", "rates"],
          "properties": {
            "base": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "quote": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "rates": {
              "type": "array",
              "maxItems": 5000,
              "items": { "type": ["number", "null"], "exclusiveMinimum": 0 }
            }
          }
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "normalized",
        "rawRedistribution",
        "frequency",
        "priceField",
        "license",
        "cachedAt",
        "attribution"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["twelve_data", "yahoo_finance", "none"]
        },
        "normalized": { "const": true },
        "rawRedistribution": { "const": false },
        "frequency": { "const": "daily" },
        "priceField": {
          "type": "string",
          "enum": ["close", "adjusted_close", "by_asset"]
        },
        "priceFieldBySymbol": {
          "type": "object",
          "propertyNames": { "type": "string", "minLength": 1, "maxLength": 24 },
          "additionalProperties": {
            "type": "string",
            "enum": ["close", "adjusted_close"]
          }
        },
        "license": { "type": "string", "minLength": 1 },
        "cachedAt": { "type": "string", "format": "date-time" },
        "attribution": { "type": "string", "minLength": 1 }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "state": {
      "type": "string",
      "enum": ["published", "live_api", "stale", "degraded", "unavailable", "ruin"]
    }
  }
}
